class Solution {
    public int[] searchRange(int[] nums, int target) {
        int first = getFirst(nums, target);
        int last = getLast(nums, target);
        return new int[]{first, last};
    }
    private int getFirst(int[] nums, int target){// lower bound
        int left = 0, right = nums.length - 1;
        int ans = -1;
        while(left <= right){
            int mid = left + (right - left)/2;

            if(nums[mid] == target){
                right = mid - 1;
                ans = mid;
            }
            else if(nums[mid] > target){
                right = mid - 1;
            }
            else{
                left = mid + 1;
            }
        }
        return ans;
    }
    private int getLast(int[] nums, int target){// upper bound
        int left = 0, right = nums.length - 1;
        int ans = -1;
        while(left < right){
            int mid = left + (right - left)/2;

            if(nums[mid] == target){
                left = mid + 1;
                ans = mid;
            }
            else if(nums[mid] < target){
                left = mid + 1;
            }
            else{
                right = mid - 1;
            }
        }
        return ans;
    }
}
